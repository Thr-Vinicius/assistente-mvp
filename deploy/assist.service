# deploy/assist.service
[Unit]
Description=Assistente Web (FastAPI/Uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/assist
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/assist/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=2
User=root
Group=root

[Install]
WantedBy=multi-user.target
